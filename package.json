{
  "name": "aegis-rewrite",
  "version": "1.0.0",
  "description": "Aegis ReWrite — Point at code. Find problems. Fix them.",
  "main": "src/main.js",
  "scripts": {
    "start": "node launcher.js",
    "build:win": "electron-builder --win portable",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.veritas.aegis-rewrite",
    "productName": "Aegis ReWrite",
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "src/**/*",
      "backend/**/*",
      "!backend/__pycache__/**",
      "!backend/*.db",
      "!backend/venv/**",
      "!backend/data/**"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*", "!__pycache__/**", "!*.db", "!venv/**", "!data/**"]
      }
    ],
    "asar": false
  },
  "author": "RJ Lopez",
  "license": "MIT",
  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "^25.1.8"
  }
}
